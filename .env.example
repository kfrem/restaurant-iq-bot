# Copy this file to .env and fill in your values
# cp .env.example .env

# ── REQUIRED ─────────────────────────────────────────────────────────────────
# Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_token_here

# ── AI BACKEND ────────────────────────────────────────────────────────────────
# Option A (RECOMMENDED for SaaS): Anthropic Claude API
#   • No GPU server needed — ~$0.05/restaurant/month at typical usage
#   • claude-haiku-4-5 for analysis, claude-sonnet-4-6 for reports
#   • Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Option B (self-hosted): Local Ollama — leave ANTHROPIC_API_KEY blank to use this
#   • Requires a machine with 20+ GB RAM and Ollama installed
#   • Vision model for invoice/receipt reading and weekly reports
OLLAMA_MODEL=qwen3-vl:30b
#   • Fast text model for voice note and text analysis
OLLAMA_TEXT_MODEL=gemma3:4b
#   • Ollama API host (change if Ollama is on a different machine)
OLLAMA_HOST=http://localhost:11434

# ── VOICE TRANSCRIPTION ───────────────────────────────────────────────────────
# Whisper model size: tiny (fastest) | base (recommended) | small | medium (best)
WHISPER_MODEL_SIZE=base
# Force a transcription language (e.g. en, es, fr, it). Leave blank for auto-detect.
WHISPER_LANGUAGE=

# ── DATABASE ──────────────────────────────────────────────────────────────────
# SQLite file path — use an absolute path in production
DB_PATH=restaurant_iq.db

# ── SAAS / BILLING ────────────────────────────────────────────────────────────
# Stripe API keys for subscription billing
# Get them at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# URL shown to users when trial expires or an upgrade prompt is triggered
UPGRADE_URL=https://restaurantiq.app/upgrade

# ── SCHEDULED REPORTS ─────────────────────────────────────────────────────────
# Full weekly briefing: auto-sent on this day at this time (server local time)
REPORT_DAY=monday
REPORT_TIME=08:00

# Daily flash report: sent each evening with that day's summary
FLASH_REPORT_TIME=18:00

# ── ADMIN ALERTS ──────────────────────────────────────────────────────────────
# Telegram user ID of the platform admin (receives AI backend health alerts)
# Find your ID by messaging @userinfobot on Telegram
ADMIN_TELEGRAM_ID=
