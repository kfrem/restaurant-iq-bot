# Copy this file to .env and fill in your values
# For Railway/cloud deployments, set these as environment variables in your project settings.

# Your Telegram bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=your_token_here

# Ollama host URL — leave blank for localhost (default).
# For Railway or other cloud deployments, point this at your Ollama service.
# Example: http://my-ollama-service.railway.internal:11434
OLLAMA_HOST=

# Vision model for invoice/photo reading (requires ~20 GB RAM)
# Smaller alternative: qwen2.5-vl:7b (~5 GB RAM)
OLLAMA_MODEL=qwen3-vl:30b

# Fast text model for quick text analysis (~3 GB RAM)
OLLAMA_TEXT_MODEL=gemma3:4b

# Whisper model size: tiny, base, small, medium (base = best balance)
WHISPER_MODEL_SIZE=base

# Database file path — use an absolute path in production to survive restarts
# On Railway, use a mounted volume path (e.g. /data/restaurant_iq.db)
DB_PATH=restaurant_iq.db
