# Copy this file to .env and fill in your values
# cp .env.example .env

# ── REQUIRED ─────────────────────────────────────────────────────────────────
# Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_token_here

# ── AI MODELS ─────────────────────────────────────────────────────────────────
# Vision model — used for invoice/receipt photo reading and weekly reports
# Default: qwen3-vl:30b (requires ~20 GB RAM)
# Alternative for low-memory machines: qwen2.5-vl:7b
OLLAMA_MODEL=qwen3-vl:30b

# Fast text model — used for voice note and text message analysis
OLLAMA_TEXT_MODEL=gemma3:4b

# Ollama API host — change if Ollama runs on a different machine
OLLAMA_HOST=http://localhost:11434

# ── VOICE TRANSCRIPTION ───────────────────────────────────────────────────────
# Whisper model size: tiny (fastest) | base (recommended) | small | medium (most accurate)
WHISPER_MODEL_SIZE=base

# Force a specific transcription language, e.g. en, es, fr, it, de
# Leave blank (default) to auto-detect the language from each voice note
WHISPER_LANGUAGE=

# ── DATABASE ──────────────────────────────────────────────────────────────────
# SQLite file path — use an absolute path in production
DB_PATH=restaurant_iq.db

# ── SCHEDULED REPORTS ─────────────────────────────────────────────────────────
# Weekly briefings are auto-sent on this day at this time (server local time)
# Day values: monday, tuesday, wednesday, thursday, friday, saturday, sunday
REPORT_DAY=monday
REPORT_TIME=08:00

# ── ADMIN ALERTS (OPTIONAL) ───────────────────────────────────────────────────
# Telegram user ID of the admin who receives Ollama health-check alerts
# Find your ID by messaging @userinfobot on Telegram
# Leave blank to disable admin alerts
ADMIN_TELEGRAM_ID=
