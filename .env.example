# Copy this file to .env and fill in your values
# cp .env.example .env

# ── REQUIRED ─────────────────────────────────────────────────────────────────
# Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_token_here

# ── AI BACKEND — set any combination, cheapest used automatically ─────────────
#
# STEP 1 — Pick a FREE backend (get at least one of these):
#
# Groq — free tier, very fast, text analysis & reports
#   Get key (no card needed): https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
#
# Google Gemini — free tier, text + invoice photo reading (vision)
#   Get key (no card needed): https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_FAST_MODEL=gemini-1.5-flash
GEMINI_SMART_MODEL=gemini-1.5-pro
#
# STEP 2 — Anthropic Claude (Enterprise clients only, paid)
#   Only needed if you sell Enterprise (£999/mo) subscriptions
#   Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
CLAUDE_SMART_MODEL=claude-sonnet-4-6
#
# STEP 3 (optional) — Local Ollama fallback (self-hosted, needs GPU machine)
OLLAMA_MODEL=qwen3-vl:30b
OLLAMA_TEXT_MODEL=gemma3:4b
OLLAMA_HOST=http://localhost:11434

# ── VOICE TRANSCRIPTION ───────────────────────────────────────────────────────
# Whisper model size: tiny (fastest) | base (recommended) | small | medium (best)
WHISPER_MODEL_SIZE=base
# Force a transcription language (e.g. en, es, fr, it). Leave blank for auto-detect.
WHISPER_LANGUAGE=

# ── DATABASE ──────────────────────────────────────────────────────────────────
# SQLite file path — use an absolute path in production
DB_PATH=restaurant_iq.db

# ── SAAS / BILLING ────────────────────────────────────────────────────────────
# Stripe API keys for subscription billing
# Get them at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# URL shown to users when trial expires or an upgrade prompt is triggered
UPGRADE_URL=https://restaurantiq.app/upgrade

# ── SCHEDULED REPORTS ─────────────────────────────────────────────────────────
# Full weekly briefing: auto-sent on this day at this time (server local time)
REPORT_DAY=monday
REPORT_TIME=08:00

# Daily flash report: sent each evening with that day's summary
FLASH_REPORT_TIME=18:00

# ── ADMIN ALERTS ──────────────────────────────────────────────────────────────
# Telegram user ID of the platform admin (receives AI backend health alerts)
# Find your ID by messaging @userinfobot on Telegram
ADMIN_TELEGRAM_ID=

# ── HUMAN ADVISORY TEAM ───────────────────────────────────────────────────────
# Comma-separated Telegram user IDs of your analyst team
# These IDs unlock the /analyst command suite for internal use
ANALYST_TELEGRAM_IDS=

# Hours the analyst has to review a report before it is released automatically
ANALYST_REVIEW_WINDOW_HOURS=4

# Default region for new restaurants (used for supplier search filtering)
# Options: london, nationwide, north, south, midlands, scotland, wales
DEFAULT_REGION=london

# ── FLIVIO INTEGRATION ────────────────────────────────────────────────────────
# URL of your Flivio API (leave blank if not yet integrated via REST)
FLIVIO_API_URL=

# Secret API key for Flivio REST calls (set in your Flivio .env as API_KEY)
FLIVIO_API_KEY=

# Public URL of the Flivio dashboard (shown to Managed/Enterprise clients)
FLIVIO_DASHBOARD_URL=https://app.flivio.com/dashboard
