# Copy this file to .env and fill in your values.
# For Railway/cloud deployments, set these as environment variables in your project settings.

# Your Telegram bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=your_token_here

# Your Google Gemini API key from https://aistudio.google.com/app/apikey (required)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model for text analysis and invoice photo reading
GEMINI_MODEL=gemini-1.5-flash

# Gemini model for weekly report generation (higher quality, slightly more expensive)
GEMINI_REPORT_MODEL=gemini-1.5-pro

# Whisper model size for voice transcription: tiny, base, small, medium
# base = best balance of speed and accuracy
WHISPER_MODEL_SIZE=base

# Database file path — use an absolute path in production to survive restarts.
# On Railway, mount a volume and use its path (e.g. /data/restaurant_iq.db)
DB_PATH=restaurant_iq.db
