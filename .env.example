# ============================================================
# Restaurant-IQ Bot — Environment Variables
# ============================================================
# Copy this file to .env for local development.
# On Railway: paste each variable into the Variables tab.
# ============================================================


# ── REQUIRED FROM DAY ONE ──────────────────────────────────

# Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_token_here

# Google Gemini API key — FREE, no credit card needed
# Get it here → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here


# ── ADD BEFORE YOU HIT 50 RESTAURANTS ─────────────────────
# Groq API key — FREE, fast AI inference
# Get it here → https://console.groq.com/keys
# The system will switch to Groq automatically once you
# have 50+ restaurants AND this key is set.
GROQ_API_KEY=your_groq_api_key_here


# ── ADD BEFORE YOU HIT 100 RESTAURANTS ────────────────────
# Anthropic (Claude) API key — PAID, best quality reports
# Get it here → https://console.anthropic.com/
# Add $10 credit to start — Claude Haiku is very cheap.
# The system will switch to Claude automatically once you
# have 100+ restaurants AND this key is set.
ANTHROPIC_API_KEY=your_anthropic_api_key_here


# ── OPTIONAL SETTINGS (safe to leave as defaults) ─────────

# Gemini model: gemini-1.5-flash (free) or gemini-1.5-pro (paid)
GEMINI_MODEL=gemini-1.5-flash

# Whisper transcription quality: tiny / base / small / medium
# base = best balance of speed and accuracy
WHISPER_MODEL_SIZE=base

# SQLite database file path
DB_PATH=restaurant_iq.db
