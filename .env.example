# Copy this file to .env and fill in your values

# Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_token_here

# Vision model for invoice/photo reading (large, best quality)
OLLAMA_MODEL=qwen3-vl:30b

# Fast text model for quick text analysis
OLLAMA_TEXT_MODEL=gemma3:4b

# Whisper model size: tiny, base, small, medium (base = best balance)
WHISPER_MODEL_SIZE=base

# Database file path
DB_PATH=restaurant_iq.db
