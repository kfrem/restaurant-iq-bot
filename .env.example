# Copy this file to .env and fill in your values
# For Railway/cloud deployment, set these as environment variables in the Variables tab

# Your Telegram bot token from @BotFather (REQUIRED)
TELEGRAM_BOT_TOKEN=your_token_here

# Ollama server URL (REQUIRED for cloud deployment — point to your Ollama instance)
# Local default: http://localhost:11434
# Railway: set to your Ollama service URL, e.g. http://ollama.railway.internal:11434
OLLAMA_HOST=http://localhost:11434

# Vision model for invoice/photo reading (large, best quality)
OLLAMA_MODEL=qwen3-vl:30b

# Fast text model for quick text analysis
OLLAMA_TEXT_MODEL=gemma3:4b

# Whisper model size: tiny, base, small, medium (base = best balance)
WHISPER_MODEL_SIZE=base

# Database file path
DB_PATH=restaurant_iq.db
