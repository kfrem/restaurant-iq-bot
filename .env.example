# Copy this file to .env and fill in your values
# For Railway/cloud deployment, set these as environment variables in the Variables tab

# Your Telegram bot token from @BotFather (REQUIRED)
TELEGRAM_BOT_TOKEN=your_token_here

# Google Gemini API key (REQUIRED) — free at https://aistudio.google.com/app/apikey
# Free tier: 1,500 requests/day, no credit card needed
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model (optional — flash is free, pro is higher quality)
# gemini-1.5-flash  → free tier, fast (default)
# gemini-1.5-pro    → paid, better for complex reports
GEMINI_MODEL=gemini-1.5-flash

# Whisper model size: tiny, base, small, medium (base = best balance)
WHISPER_MODEL_SIZE=base

# Database file path
DB_PATH=restaurant_iq.db
